[
  {
    "type": "event",
    "name": "DelegationGranted",
    "inputs": [
      { "name": "delegationHash", "type": "bytes32", "indexed": true, "internalType": "bytes32" },
      { "name": "delegate",       "type": "address", "indexed": true, "internalType": "address" },
      { "name": "delegator",      "type": "address", "indexed": true, "internalType": "address" }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "DelegationRevoked",
